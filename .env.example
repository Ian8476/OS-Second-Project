# =========================================================
# Entorno de desarrollo - copiar a .env y ajustar
# =========================================================

# --- App ---
APP_ENV=development
APP_NAME=mediaintel
LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Postgres ---
POSTGRES_USER=mediaintel
POSTGRES_PASSWORD=mediaintel_dev
POSTGRES_DB=mediaintel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://mediaintel:mediaintel_dev@postgres:5432/mediaintel
DATABASE_URL_SYNC=postgresql+psycopg://mediaintel:mediaintel_dev@postgres:5432/mediaintel

# --- RabbitMQ ---
RABBITMQ_USER=mediaintel
RABBITMQ_PASSWORD=mediaintel_dev
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
CELERY_BROKER_URL=amqp://mediaintel:mediaintel_dev@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_PUBSUB_URL=redis://redis:6379/2

# --- MinIO ---
MINIO_ROOT_USER=mediaintel
MINIO_ROOT_PASSWORD=mediaintel_dev
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=mediaintel-cases
MINIO_USE_SSL=false

# --- Worker concurrency (gestion de procesos) ---
WORKER_TEXT_CONCURRENCY=4
WORKER_AUDIO_CONCURRENCY=1
WORKER_IMAGE_CONCURRENCY=2
WORKER_AGGREGATOR_CONCURRENCY=2

# --- Limites de tarea ---
TASK_MAX_RETRIES=3
TASK_RETRY_BACKOFF_BASE=5
TASK_SOFT_TIME_LIMIT=120
TASK_HARD_TIME_LIMIT=180

# --- Modelos ML ---
WHISPER_MODEL_SIZE=tiny
YOLO_MODEL=yolov8n.pt

# --- Dashboard ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
